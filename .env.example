# Copy this file to `.env.local` for local development.
# For production, set the same variables as build-time environment variables.
# This file must only contain safe placeholder values.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
# Optional alias from Supabase dashboard examples (same public client key):
# VITE_SUPABASE_PUBLISHABLE_KEY=your-public-anon-key

# Never expose server-only credentials in VITE_* variables:
# SUPABASE_SERVICE_ROLE_KEY=...
